# Document parser (local Windows dev — do NOT use these paths in Docker)
# DOC_PARSER_PYTHON_PATH=.venv-markitdown\Scripts\python.exe
# DOC_PARSER_SCRIPT_PATH=src\services\python\parse_document.py
#
# Docker / Linux (set automatically by docker-compose and the backend image):
# DOC_PARSER_PYTHON_PATH=/app/.venv-markitdown/bin/python
# DOC_PARSER_SCRIPT_PATH=/app/src/services/python/parse_document.py
# MARKITDOWN_REPO_DIR=/app/.markitdown-src
# MARKITDOWN_VENV_DIR=/app/.venv-markitdown

# MVP demo defaults
ENABLE_AUDIO_PROCESSING_QUEUE=false
ENABLE_REALTIME_FEEDBACK=true
ENABLE_FINAL_EVALUATION=true
LLM_ANALYSIS_INTERVAL=30
